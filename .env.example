# Copy to .env and fill in. .env is gitignored.
RITUAL_RPC_URL=https://rpc.ritualfoundation.org
RITUAL_WS_URL=wss://rpc.ritualfoundation.org/ws
RITUAL_VERIFIER_URL=https://rpc.ritualfoundation.org/api/verify

# Your testnet deployer key (get testnet RITUAL from https://faucet.ritualfoundation.org)
PRIVATE_KEY=0xyour_private_key_here

# Only needed if your environment intercepts TLS (e.g. corporate/AV proxy). Leave unset otherwise.
# NODE_TLS_REJECT_UNAUTHORIZED=0
